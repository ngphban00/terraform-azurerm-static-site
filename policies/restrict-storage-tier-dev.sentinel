import "tfplan/v2" as tfplan
import "tfrun" as tfrun

# Enforce Cool access tier only in dev workspaces to minimize cost.
# Staging and prod are permitted to use Hot tier.

is_dev = tfrun.workspace.name matches ".*-dev$"

storage_accounts = filter tfplan.resource_changes as _, rc {
    rc.type is "azurerm_storage_account" and
    (rc.change.actions contains "create" or
     rc.change.actions contains "update")
}

deny_hot_tier = rule {
    all storage_accounts as _, sa {
        sa.change.after.access_tier in ["Cool", null]
    }
}

main = rule {
    not is_dev or deny_hot_tier
}
